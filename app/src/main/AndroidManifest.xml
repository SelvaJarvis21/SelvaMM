<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SelvaMoneyManager" >

        <!-- AccountListActivity is now the LAUNCH activity -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SelvaMoneyManager" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Secondary activity to add accounts -->
        <activity
            android:name=".accounts.AddAccountActivity"
            android:exported="false" />

        <activity android:name=".trans.TransactionsActivity" />
        <activity android:name=".trans.AddTransactionActivity" />
        <activity android:name=".stats.StatsActivity" />
    </application>

</manifest>
